# =============================================================================
# Monorepo Enjambre Legado — referencia de variables de entorno
# =============================================================================
# Secretos reales: usa apps/<app>/.env.local (gitignored). Aquí solo placeholders.
# Vercel: mismas claves en el proyecto con el Root Directory correcto.
# =============================================================================

# -----------------------------------------------------------------------------
# apps/nucleo — SPA Vite (+ landing Next opcional)
# Archivo local: apps/nucleo/.env.local
# -----------------------------------------------------------------------------
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# (o) VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# VITE_PUBLIC_URL_TIENDA=https://tu-tienda.vercel.app
# VITE_PUBLIC_URL_CAMPO=https://tu-campo.vercel.app
# NEXT_PUBLIC_URL_TIENDA=...
# NEXT_PUBLIC_URL_CAMPO=...

# -----------------------------------------------------------------------------
# apps/tienda — Next.js
# Archivo local: apps/tienda/.env.local
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# NEXT_PUBLIC_SITE_URL=https://tu-tienda.vercel.app
# TRANSBANK_COMMERCE_CODE=solo_servidor
# TRANSBANK_API_KEY=solo_servidor
# SUPABASE_SERVICE_ROLE_KEY=solo_servidor
# Integraciones (ver apps/tienda/.env.example): SII_*, BANK_*, NOTIFY_*, BOLETAS_*, DTE_*, INTEGRATIONS_CRON_SECRET

# -----------------------------------------------------------------------------
# apps/campo — Next.js (@supabase/ssr)
# Archivo local: apps/campo/.env.local
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# (o) NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# -----------------------------------------------------------------------------
# packages/auth (Next) — NEXT_PUBLIC_* en la app que consuma el paquete
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Scripts / migraciones (nunca en el cliente ni en NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
