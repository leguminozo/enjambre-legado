# =============================================================================
# Monorepo Enjambre Legado — referencia de variables de entorno
# =============================================================================
# Secretos reales: usa apps/<app>/.env.local (gitignored). Aquí solo placeholders.
# Vercel: mismas claves en el proyecto con el Root Directory correcto.
# =============================================================================

# -----------------------------------------------------------------------------
# apps/nucleo — Next.js 16 (dashboard + BFF)
# Archivo local: apps/nucleo/.env.local
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# (o) NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_ROLE_KEY=solo_servidor
# INTERNAL_API_SECRET=secreto_dedicado_bff_interno  # obligatorio en producción (nunca reutilizar service role)
# NEXT_PUBLIC_URL_TIENDA=https://tu-tienda.vercel.app
# NEXT_PUBLIC_URL_CAMPO=https://tu-campo.vercel.app
# NEXT_PUBLIC_NUCLEO_API_URL=https://tu-nucleo.vercel.app
#
# Plataforma (Vercel nucleo) — no valores de negocio:
# SII_CLAVE_ENCRYPTION_KEY=minimo_32_chars_random_seguro_____
# CRON_SECRET=secreto_cron_vercel
# SII_AUTO_EMIT_BOLETA=true
# BANCO_CHILE_WEBHOOK_SECRET=hmac_shared_con_banco
# PAYMENT_PROVIDER=flow
# FLOW_API_KEY=...
# FLOW_SECRET=...
# FLOW_API_URL=https://www.flow.cl/api
# TRANSBANK_COMMERCE_CODE=...
# TRANSBANK_API_KEY=...
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_redis_token
# -----------------------------------------------------------------------------
# apps/tienda — Next.js 16 (e-commerce + admin)
# Archivo local: apps/tienda/.env.local
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# NEXT_PUBLIC_SITE_URL=https://tu-tienda.vercel.app
# NEXT_PUBLIC_NUCLEO_API_URL=https://tu-nucleo.vercel.app
# INTERNAL_API_SECRET=secreto_dedicado_bff_interno
# SUPABASE_SERVICE_ROLE_KEY=solo_servidor
# Integraciones (ver apps/tienda/.env.example): TRANSBANK_*, FLOW_*, SII_*, BANK_*, NOTIFY_*, BOLETAS_*, DTE_*, INTEGRATIONS_CRON_SECRET

# -----------------------------------------------------------------------------
# apps/campo — Next.js 16 (PWA de terreno)
# Archivo local: apps/campo/.env.local
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# (o) NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# NEXT_PUBLIC_NUCLEO_API_URL=https://nucleo-theta.vercel.app
# SUPABASE_SERVICE_ROLE_KEY=solo_servidor

# -----------------------------------------------------------------------------
# packages/auth — NEXT_PUBLIC_* en la app que consuma el paquete
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Scripts / migraciones (nunca en el cliente ni en NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# -----------------------------------------------------------------------------
# Banco Chile / SumUp / SII negocio → config-en-UI (Núcleo)
# -----------------------------------------------------------------------------
# Credenciales de negocio se configuran en la app (cifradas con SII_CLAVE_ENCRYPTION_KEY).
# En Vercel solo:
# BANCO_CHILE_WEBHOOK_SECRET=hmac_shared
# (OAuth client/user, SumUp API key, P12, RUT, CAF → UI módulo correspondiente)
