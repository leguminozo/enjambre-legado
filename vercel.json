{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npx pnpm@10.32.1 install --frozen-lockfile",
  "buildCommand": "npx pnpm@10.32.1 exec turbo run build --filter=@enjambre/tienda",
  "framework": "nextjs",
  "outputDirectory": null,
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "https://tienda-three-gamma.vercel.app/:path*"
    }
  ]
}