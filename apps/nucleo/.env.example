# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
INTERNAL_API_SECRET=your_internal_api_secret

# Enlaces al ecosistema (producción: URLs de Vercel de tienda y campo)
NEXT_PUBLIC_URL_TIENDA=https://tu-tienda.vercel.app
NEXT_PUBLIC_URL_CAMPO=https://tu-campo.vercel.app
# URL pública de este proyecto Núcleo (Flow urlConfirmation + APIs cross-app)
NEXT_PUBLIC_NUCLEO_API_URL=https://tu-nucleo.vercel.app

# --- Pasarela de pagos Flow.cl (default) ---
PAYMENT_PROVIDER=flow
FLOW_API_URL=https://www.flow.cl/api
FLOW_API_KEY=your_flow_api_key
FLOW_SECRET=your_flow_secret_key
# Sandbox: FLOW_API_URL=https://sandbox.flow.cl/api

# --- Pasarela de pagos Transbank Webpay Plus ---
# PAYMENT_PROVIDER=transbank
TRANSBANK_COMMERCE_CODE=your_commerce_code
TRANSBANK_API_KEY=your_api_key
TRANSBANK_ENVIRONMENT=integration
# Sandbox: TRANSBANK_ENVIRONMENT=integration
# Production: TRANSBANK_ENVIRONMENT=production

# --- Banco Chile Webhooks ---
BANCO_CHILE_WEBHOOK_SECRET=your_webhook_secret

# --- Rate Limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# --- Notification worker (Vercel Cron + trigger manual) ---
# Vercel inyecta CRON_SECRET automáticamente al habilitar crons en vercel.json.
# NOTIFICATIONS_WORKER_SECRET habilita POST /api/notifications/trigger-worker con x-worker-secret.
# INTEGRATIONS_CRON_SECRET es alias legacy (misma clave aceptada en /api/cron/notifications).
# CRON_SECRET=
# NOTIFICATIONS_WORKER_SECRET=
# INTEGRATIONS_CRON_SECRET=
