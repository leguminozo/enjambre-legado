DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?schema=public"

# Supabase connection pooling (optional but recommended)
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# Auth token para EIRL (producción)
EIRL_AUTH_TOKEN=""

# Empresa ID por defecto
EIRL_EMPRESA_ID=""

# SumUp API
SUMUP_API_KEY="sk_test_..."
SUMUP_SANDBOX="true"

# URL de la app (para callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
