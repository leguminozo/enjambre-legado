generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Empresa {
  id                String   @id @default(cuid())
  razonSocial       String
  rut               String   @unique
  giro              String
  direccion         String
  comuna            String
  ciudad            String
  region            String
  telefono          String?
  email             String?
  web               String?
  capitalInicial    Float
  fechaConstitucion DateTime
  tipoActividad     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  facturasEmitidas   FacturaEmitida[]
  facturasRecibidas  FacturaRecibida[]
  gastos             Gasto[]
  impuestos          Impuesto[]
  periodos           PeriodoContable[]
  reportes           Reporte[]
  calculosIA         CalculoIA[]
  usuariosEmpresa    UsuariosEmpresa[]
  terceros           Tercero[]
  conciliacionesSumUp ConciliacionSumUp[]
}

model UsuariosEmpresa {
  id        String   @id @default(cuid())
  userId    String
  empresaId String
  rol       String
  createdAt DateTime @default(now())

  empresa  Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([userId, empresaId])
  @@index([empresaId])
}

model Tercero {
  id        String   @id @default(cuid())
  tipo      String
  rut       String
  nombre    String
  email     String?
  telefono  String?
  direccion String?
  giro      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  empresaId        String  @default("default")
  empresa          Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  facturasEmitidas FacturaEmitida[] @relation("FacturaCliente")
  facturasRecibidas FacturaRecibida[] @relation("FacturaProveedor")
  gastos           Gasto[]

  @@unique([empresaId, rut])
  @@index([empresaId])
}

model FacturaEmitida {
  id              String   @id @default(cuid())
  numero          String
  fecha           DateTime
  fechaVencimiento DateTime?
  montoTotal      Float
  montoNeto       Float
  montoIva        Float
  montoExento     Float    @default(0)
  montoIvaUsado   Float    @default(0)
  estado          String
  descripcion     String?
  tipoDocumento   String

  empresaId  String        @default("default")
  empresa    Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  clienteId  String?
  cliente    Tercero?      @relation("FacturaCliente", fields: [clienteId], references: [id])
  periodoId  String
  periodo    PeriodoContable @relation(fields: [periodoId], references: [id], onDelete: Cascade)
  conciliacionesSumUp ConciliacionSumUp[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([empresaId, numero])
  @@index([empresaId])
  @@index([clienteId])
}

model FacturaRecibida {
  id              String   @id @default(cuid())
  numero          String
  fecha           DateTime
  fechaVencimiento DateTime?
  montoTotal      Float
  montoNeto       Float
  montoIva        Float
  montoExento     Float    @default(0)
  montoIvaUsado   Float    @default(0)
  estado          String
  descripcion     String?
  tipoDocumento   String

  empresaId   String        @default("default")
  empresa     Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  proveedorId String?
  proveedor   Tercero?      @relation("FacturaProveedor", fields: [proveedorId], references: [id])
  periodoId   String
  periodo     PeriodoContable @relation(fields: [periodoId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([empresaId])
  @@index([proveedorId])
}

model Gasto {
  id               String   @id @default(cuid())
  fecha            DateTime
  descripcion      String
  monto            Float
  montoIva         Float
  montoNeto        Float
  categoria        String
  tipoComprobante  String
  numeroComprobante String?
  estado           String

  empresaId   String        @default("default")
  empresa     Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  proveedorId String?
  proveedor   Tercero?      @relation(fields: [proveedorId], references: [id])
  periodoId   String
  periodo     PeriodoContable @relation(fields: [periodoId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([empresaId])
}

model Impuesto {
  id              String    @id @default(cuid())
  tipo            String
  periodo         String
  mes             Int?
  anio            Int
  montoDeclarado  Float
  montoPagado     Float?
  montoCalculadoIA Float?
  estado          String
  fechaDeclaracion DateTime?
  fechaPago       DateTime?
  detalles        String?

  empresaId String  @default("default")
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
}

model PeriodoContable {
  id             String   @id @default(cuid())
  nombre         String
  mes            Int
  anio           Int
  fechaInicio    DateTime
  fechaTermino   DateTime
  estado         String
  ingresosNetos  Float    @default(0)
  egresosNetos   Float    @default(0)
  utilidadBruta  Float    @default(0)
  utilidadNeta   Float    @default(0)
  ivaDebito      Float    @default(0)
  ivaCredito     Float    @default(0)
  ivaPagar       Float    @default(0)
  ppmCalculado   Float    @default(0)

  empresaId        String  @default("default")
  empresa          Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  facturasEmitidas FacturaEmitida[]
  facturasRecibidas FacturaRecibida[]
  gastos           Gasto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empresaId, mes, anio])
  @@index([empresaId])
}

model Reporte {
  id          String   @id @default(cuid())
  tipo        String
  nombre      String
  descripcion String?
  periodo     String
  mes         Int?
  anio        Int
  datos       String
  archivoUrl  String?
  estado      String

  empresaId String  @default("default")
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
}

model CalculoIA {
  id          String   @id @default(cuid())
  tipo        String
  parametros  String
  resultado   String
  confianza   Float?
  prompt      String?
  respuestaIA String?
  estado      String
  error       String?

  empresaId String  @default("default")
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
}

model ConciliacionSumUp {
  id            String   @id @default(cuid())
  checkoutId    String?
  transactionId String?
  monto         Float
  comision      Float    @default(0)
  neto          Float
  estado        String   @default("PENDIENTE")
  tipo          String   @default("servicio")
  facturaId     String?
  observaciones String?

  empresaId String  @default("default")
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  factura   FacturaEmitida? @relation(fields: [facturaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
  @@index([transactionId])
  @@index([facturaId])
}

model ConfiguracionIA {
  id          String   @id @default(cuid())
  clave       String   @unique
  valor       String
  descripcion String?
  tipo        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
