# Copiar a .env.local para desarrollo local (no commitear secretos).
# En Vercel (proyecto con Root = apps/campo): mismas claves en Production y Preview.
# Sin URL + clave pública, el middleware ya no devuelve 500: verás /setup-error (rewrite).

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Nueva clave publishable (panel Supabase) o, si usas proyecto antiguo, solo la de abajo.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxxxxx

# Alternativa equivalente a la publishable (clave anon pública del proyecto).
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
