# Banco Chile Empresas API Credentials
# Obtener en: https://apistore.bancochile.cl/banco-chile/sandbox

BANCO_CHILE_CLIENT_ID=tu_client_id_aqui
BANCO_CHILE_CLIENT_SECRET=tu_client_secret_aqui
BANCO_CHILE_USERNAME=tu_username_aqui
BANCO_CHILE_PASSWORD=tu_password_aqui
BANCO_CHILE_ENVIRONMENT=sandbox

# Notas:
# - sandbox: para pruebas con el sandbox de Banco Chile
# - production: para producción real
# - Las credenciales se guardan también en la DB (banco_chile_config) por empresa
