NEXT_PUBLIC_SUPABASE_URL=your_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_SITE_URL=https://tu-tienda.vercel.app
# BFF Núcleo — obligatorio para checkout y pagos Flow
NEXT_PUBLIC_NUCLEO_API_URL=https://tu-nucleo.vercel.app

# Google Maps (requerido para mapa de envío / tienda física)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Botón flotante WhatsApp en la tienda pública (solo dígitos, código país; ej. 56912345678)
# NEXT_PUBLIC_WHATSAPP_E164=56912345678
# Video de YouTube en landing (ID del video, ej. dQw4w9WgXcQ)
# NEXT_PUBLIC_YOUTUBE_VIDEO_ID=dQw4w9WgXcQ
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Clave compartida tienda → Núcleo (internal routes). Si no se define, usa SUPABASE_SERVICE_ROLE_KEY.
# INTERNAL_API_SECRET=obligatorio_en_produccion

# Pagos: se configuran en Núcleo (PAYMENT_PROVIDER, FLOW_*, TRANSBANK_*).
# En Vercel tienda solo necesitas NEXT_PUBLIC_NUCLEO_API_URL apuntando al BFF.

# --- Integraciones (solo servidor; no uses NEXT_PUBLIC_*) ---
# SII: credenciales cuando exista conector real (nunca en integrations.config en DB)
# SII_API_KEY=
# SII_CLIENT_ID=
# SII_CLIENT_SECRET=
# Bancos / agregador Open Finance
# BANK_API_KEY=
# BANK_CLIENT_ID=
# BANK_CLIENT_SECRET=
# Notificaciones
# NOTIFY_SENDGRID_API_KEY=
# NOTIFY_SMTP_HOST=
# NOTIFY_SMTP_USER=
# NOTIFY_SMTP_PASS=
# Boletas / DTE (terceros)
# BOLETAS_API_KEY=
# DTE_API_TOKEN=
# Cron / jobs HTTP (futuro): header compartido para rutas internas
# INTEGRATIONS_CRON_SECRET=
