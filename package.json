{
  "name": "enjambre-legado",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "pnpm --filter @enjambre/contable test && pnpm --filter @enjambre/fiscal test && pnpm --filter @enjambre/pricing test && pnpm --filter @enjambre/auth test && pnpm --filter @enjambre/nucleo test && pnpm --filter @enjambre/tienda test",
    "test:e2e:nucleo": "pnpm --filter @enjambre/nucleo test:e2e",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "skills:supabase": "npx skills add supabase/agent-skills",
    "build:ci:tienda": "pnpm install --frozen-lockfile && pnpm turbo build --filter=@enjambre/tienda",
    "build:ci:nucleo": "pnpm install --frozen-lockfile && pnpm turbo build --filter=@enjambre/nucleo",
    "verify": "bash scripts/verify-before-vercel.sh",
    "verify:ci": "pnpm turbo build --filter=@enjambre/contable --filter=@enjambre/nucleo --filter=@enjambre/tienda",
    "verify:fast": "pnpm turbo build --filter=@enjambre/contable --filter=@enjambre/nucleo --filter=@enjambre/tienda",
    "go-live:check": "node scripts/go-live-check.mjs",
    "go-live:phase0": "node scripts/go-live-phase0.mjs",
    "go-live:phase0:build": "node scripts/go-live-phase0.mjs --build",
    "go-live:phase0:apply": "bash scripts/go-live-phase0-apply.sh",
    "go-live:init-secrets": "bash scripts/init-secrets-local.sh",
    "go-live:bootstrap": "bash scripts/bootstrap-local-env.sh",
    "go-live:vercel-setup": "node scripts/setup-vercel-projects.mjs",
    "go-live:vercel-env": "bash scripts/push-vercel-env.sh",
    "go-live:github-secrets": "bash scripts/push-github-secrets.sh",
    "go-live:smoke": "node scripts/smoke-test.mjs",
    "go-live:smoke:prod": "node scripts/smoke-production.mjs",
    "vercel:build": "vercel build",
    "dev:vercel": "vercel dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": ["tesseract.js"]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/leaflet": "^1.9.21",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "turbo": "^2.9.14",
    "typescript-eslint": "^8.60.1"
  }
}